# Copy to .env and fill in your values
# Never commit .env to git

# Required — OpenAI API key for all LLM calls
OPENAI_API_KEY=sk-...

# Required — S3 bucket name provisioned by CDK
PIPELINE_BUCKET=your-bucket-name

# Optional — override AWS region (default: us-east-1)
AWS_REGION=us-east-1

# Optional — LocalStack endpoint for local S3 testing only
# S3_ENDPOINT_URL=http://localhost:4566
